-- Configuration
local EGG_NAME = "EggBasket" 
local _running = true
local SHOW_LOGS = false -- Set to 'false' to disable console messages

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("EggService"):WaitForChild("RF"):WaitForChild("purchaseEgg")

-- Function to calculate arguments based on your v39 Controller analysis
local function getMaxHatchArgs()
    local hasTriple = LP:GetAttribute("TripleEggs") or false
    local hasOcto = LP:GetAttribute("OctoEggs") or false
    local extraHatches = LP:GetAttribute("HatchesPurchased") or 0
    
    return {
        [1] = EGG_NAME,
        [2] = nil,
        [3] = hasTriple, 
        [4] = true,      -- IsAutoOpening
        [5] = hasOcto,   
        [6] = (extraHatches > 0), 
        [7] = false      
    }
end

task.spawn(function()
    if SHOW_LOGS then
        print("🚀 Auto-Hatcher Active | Target Egg: " .. EGG_NAME)
    end
    
    while _running do
        local args = getMaxHatchArgs()
        
        local success, result = pcall(function()
            -- Invoking the Knit RemoteFunction
            return Remote:InvokeServer(unpack(args))
        end)
        
        if SHOW_LOGS then
            if success and result then
                -- result is usually a table of pets from the server
                local petCount = type(result) == "table" and #result or 1
                print("✅ Successfully hatched " .. petCount .. " pets!")
            elseif not success then
                warn("❌ Remote Error: " .. tostring(result))
            end
        end

        -- SYNC: Your v39 logic (Line 238) checks: tick() - LastOpened < 1
        -- Waiting 1.01 seconds ensures the server doesn't throttle/ignore the request
        task.wait(2) 
    end
end)
