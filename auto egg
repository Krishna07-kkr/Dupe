local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- // DATA & REMOTES
local EggData = require(ReplicatedStorage:WaitForChild("Data"):WaitForChild("EggData"))
local PurchaseRemote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("EggService"):WaitForChild("RF"):WaitForChild("purchaseEgg")

-- // CONFIGURATION
local TARGET_EGG = "Earth" -- The name of the egg in EggData
local ENABLED = true         -- Set to false to stop

-- // VALIDATION
if not EggData[TARGET_EGG] then
    warn("⚠️ [AUTO-HATCH] Egg '" .. TARGET_EGG .. "' not found in EggData!")
    return
end

print("🔥 Auto-Max Hatching: " .. TARGET_EGG)

task.spawn(function()
    while ENABLED do
        -- Check if player has "HatchesPurchased" (e.g., the 30x hatch)
        -- The EggController uses this to determine special hatch amounts.
        local hasSpecialHatches = (LocalPlayer:GetAttribute("HatchesPurchased") or 0) > 0
        
        local args = {
            [1] = TARGET_EGG,
            [2] = nil, 
            [3] = LocalPlayer:GetAttribute("TripleEggs") or false, -- Triple check
            [4] = true, -- MANDATORY: This triggers the server's "Max Open" logic
            [5] = LocalPlayer:GetAttribute("OctoEggs") or false,   -- Octo check
            [6] = hasSpecialHatches                                -- Special (30x) check
        }
        
        local success, result = pcall(function()
            -- InvokeServer returns the list of pets hatched
            return PurchaseRemote:InvokeServer(unpack(args))
        end)
        
        if not success then
            warn("❌ Error: " .. tostring(result))
            task.wait(1) -- Slow down if we error
        else
            -- Optional: print how many pets you got (helpful to verify 30x)
            if result and type(result) == "table" then
                -- print("Hatched " .. #result .. " pets!")
            end
        end
        
        -- The EggController uses 0.5s for normal and 0.25s for Instant Hatch.
        -- 0.1s is safe enough to not get kicked but fast enough to clear inventory.
        task.wait(0.1) 
    end
end)
