-- Configuration
local EGG_NAME = "Bunny" 
local _running = true

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("EggService"):WaitForChild("RF"):WaitForChild("purchaseEgg")

-- This function mimics the v39.openEgg logic for calculating max hatches
local function getMaxHatchArgs()
    -- Check your attributes just like the controller does
    local hasTriple = LP:GetAttribute("TripleEggs") or false
    local hasOcto = LP:GetAttribute("OctoEggs") or false
    local extraHatches = LP:GetAttribute("HatchesPurchased") or 0
    
    -- In your v39.openEgg:
    -- p106 = Triple
    -- p108 = Octo
    -- p110 = HatchesPurchased (Special/Max logic)
    
    return {
        [1] = EGG_NAME,
        [2] = nil,
        [3] = hasTriple, -- Triple Eggs boolean
        [4] = true,      -- IsAutoOpening (Set to true for continuous loop)
        [5] = hasOcto,   -- Octo Eggs boolean
        [6] = (extraHatches > 0), -- This triggers the "Special" max hatch logic
        [7] = false      -- Rotating Egg
    }
end

task.spawn(function()
    print("🚀 Auto-Hatcher: MAX HATCH (30x) Mode Active")
    
    while _running do
        local args = getMaxHatchArgs()
        
        -- Fire the remote with the full argument set
        local success, result = pcall(function()
            return Remote:InvokeServer(unpack(args))
        end)
        
        if success and result then
            -- Optional: print how many pets we got in this batch
            -- print("Hatched batch of " .. #result .. " pets!")
        end

        -- SYNC: The controller rejects anything faster than 1 second
        -- tick() - p105.LastOpened < 1
        task.wait(1.05) 
    end
end)
