-- Configuration
local EGG_NAME = "Bunny" 
local _running = true
local SHOW_LOGS = false -- Default state for console messages

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remote = ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit"):WaitForChild("Services"):WaitForChild("EggService"):WaitForChild("RF"):WaitForChild("purchaseEgg")

-- UI Toggle Setup
local ScreenGui = Instance.new("ScreenGui", LP.PlayerGui)
ScreenGui.Name = "AutoHatchUI"

local ToggleBtn = Instance.new("TextButton", ScreenGui)
ToggleBtn.Size = UDim2.new(0, 150, 0, 50)
ToggleBtn.Position = UDim2.new(0, 10, 0, 10)
ToggleBtn.Text = "Logs: ON"
ToggleBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)

ToggleBtn.MouseButton1Click:Connect(function()
    SHOW_LOGS = not SHOW_LOGS
    ToggleBtn.Text = SHOW_LOGS and "Logs: ON" or "Logs: OFF"
    ToggleBtn.BackgroundColor3 = SHOW_LOGS and Color3.fromRGB(40, 150, 40) or Color3.fromRGB(150, 40, 40)
end)

-- Mimic v39 logic
local function getMaxHatchArgs()
    local hasTriple = LP:GetAttribute("TripleEggs") or false
    local hasOcto = LP:GetAttribute("OctoEggs") or false
    local extraHatches = LP:GetAttribute("HatchesPurchased") or 0
    
    return {
        [1] = EGG_NAME,
        [2] = nil,
        [3] = hasTriple, 
        [4] = true,      
        [5] = hasOcto,   
        [6] = (extraHatches > 0), 
        [7] = false      
    }
end

task.spawn(function()
    print("🚀 Auto-Hatcher Active")
    
    while _running do
        local args = getMaxHatchArgs()
        
        local success, result = pcall(function()
            return Remote:InvokeServer(unpack(args))
        end)
        
        if success and result then
            -- Added the Toggle Check here
            if SHOW_LOGS then
                local petCount = type(result) == "table" and #result or 1
                print("✅ Successfully hatched " .. petCount .. " pets!")
            end
        elseif not success and SHOW_LOGS then
            warn("❌ Hatch failed: " .. tostring(result))
        end

        -- Adjusted wait to match the 1s server throttle mention in your comments
        task.wait(0.25) 
    end
end)
