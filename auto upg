local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Player = game:GetService("Players").LocalPlayer

-- Load Data Modules
local UpgradeData = require(ReplicatedStorage.Data.CarrotUpgrades)
local AscensionData = require(ReplicatedStorage.Data.CarrotAscensions)
local Knit = require(ReplicatedStorage.Packages.Knit)

-- Services & Controllers
local UpgradeService = Knit.GetService("CarrotUpgradesService")
local AscensionService = Knit.GetService("CarrotAscensionService")
local CustomReplica = Knit.GetController("CustomReplicaController")

-- Configuration
local ZONE = "BunnyBurrow"
local MAIN_UPGRADES = {"MoreCarrots", "FasterCarrots", "MoreSpawns"}
local CAPACITY_UPGRADE = "HigherCapacity"
local MAX_CAPACITY_TIER = 15 -- Will stop at 15/50

local function getReplicaData()
    local replica = CustomReplica:GetReplica()
    return replica and replica.Data or nil
end

local function masterLoop()
    local data = getReplicaData()
    if not data then return end
    
    local currentCarrots = Player:GetAttribute("Carrots") or 0
    
    ---------------------------------------------------------
    -- STEP 1: Check Capacity (Critical Priority)
    ---------------------------------------------------------
    local currentCapLevel = data.CarrotUpgrades[ZONE][CAPACITY_UPGRADE] or 0
    if currentCapLevel < MAX_CAPACITY_TIER then
        local capTable = UpgradeData.Upgrades[ZONE][CAPACITY_UPGRADE]
        local nextCapLevel = currentCapLevel + 1
        local capTierData = capTable.Upgrades[nextCapLevel] or capTable.Upgrades[tostring(nextCapLevel)]
        
        if capTierData and currentCarrots >= capTierData.Cost then
            print("[Master] Capacity too low ("..currentCapLevel.."). Upgrading to "..nextCapLevel)
            UpgradeService:BuyUpgrade(ZONE, CAPACITY_UPGRADE):await()
            return -- Exit to let attributes refresh
        end
    end

    ---------------------------------------------------------
    -- STEP 2: Calculate Next Upgrade vs Ascension
    ---------------------------------------------------------
    local cheapestUpgradeCost = math.huge
    local targetUpgradeName = nil
    local allMainMaxed = true

    for _, name in ipairs(MAIN_UPGRADES) do
        local currentLevel = data.CarrotUpgrades[ZONE][name] or 0
        local upgradeTable = UpgradeData.Upgrades[ZONE][name]
        local nextLevel = currentLevel + 1
        local tierData = upgradeTable.Upgrades[nextLevel] or upgradeTable.Upgrades[tostring(nextLevel)]
        
        if tierData then
            allMainMaxed = false
            if tierData.Cost < cheapestUpgradeCost then
                cheapestUpgradeCost = tierData.Cost
                targetUpgradeName = name
            end
        end
    end

    -- Get Ascension Info
    local currentAscTier = tonumber(data.CarrotAscensions[ZONE]) or 0
    local nextAscTier = currentAscTier + 1
    local ascTierData = AscensionData.Ascensions[ZONE].Tiers[nextAscTier]
    local ascCost = ascTierData and ascTierData.Cost or math.huge

    ---------------------------------------------------------
    -- STEP 3: Execution Logic
    ---------------------------------------------------------
    
    -- Priority A: If everything else is maxed, buy Ascension
    if allMainMaxed then
        if currentCarrots >= ascCost and ascTierData then
            print("[Master] All main upgrades maxed. Buying Ascension Tier " .. nextAscTier)
            AscensionService:BuyAscension(ZONE):await()
        end
        return
    end

    -- Priority B: Ascension if it's cheaper than the next main upgrade
    if ascCost <= cheapestUpgradeCost and currentCarrots >= ascCost then
        print("[Master] Ascension cheaper than upgrades. Ascending to Tier " .. nextAscTier)
        AscensionService:BuyAscension(ZONE):await()
        return
    end

    -- Priority C: Main Upgrades (More Carrots, Faster, More Spawns)
    if targetUpgradeName and currentCarrots >= cheapestUpgradeCost then
        print("[Master] Buying priority upgrade: " .. targetUpgradeName .. " for " .. cheapestUpgradeCost)
        UpgradeService:BuyUpgrade(ZONE, targetUpgradeName):await()
    end
end

-- Execution
print("Master System (Capacity-Aware) Active.")
task.spawn(function()
    while true do
        local success, err = pcall(masterLoop)
        if not success then warn("Loop Error: " .. err) end
        task.wait(1.5) 
    end
end)
