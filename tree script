-- PRIORITY LOGIC
local function getTargets()
    local found = {}
    local children = axeFolder:GetChildren()
    
    -- STEP 1: Always look for Toxic/Infected first if in All Wood mode
    if _MultiSelect then
        for _, obj in ipairs(children) do
            if obj:GetAttribute("Destroyed") ~= true then
                local name = obj.Name
                if name:find("Toxic") or name:find("Infected") then
                    table.insert(found, obj)
                end
            end
            if #found >= treeCount then return found end
        end
    end

    -- STEP 2: If we still need more trees, fill with standard selection
    for _, obj in ipairs(children) do
        if obj:GetAttribute("Destroyed") ~= true then
            local name = obj.Name
            local isMatch = false
            
            if _MultiSelect then
                -- Only add if not already in the list from Step 1
                if (name:find("Palm") or name:find("Chaos")) and not table.find(found, obj) then
                    isMatch = true
                end
            else
                -- Strictly follow the Target button if Multi is OFF
                if name:find(targetType) then
                    isMatch = true
                end
            end
            
            if isMatch then
                table.insert(found, obj)
            end
        end
        if #found >= treeCount then return found end 
    end
    
    return found
end

-- Clicking Loop
task.spawn(function()
    while _Running do
        if _Toggled then
            pcall(function() clickRemote:InvokeServer() end)
        end
        task.wait(clickSpeed)
    end
end)

-- Farming Loop
task.spawn(function()
    while _Running do
        if _Toggled and rootPart then
            if not character:FindFirstChild("Axe") then
                toggleRemote:InvokeServer("Axe")
                task.wait(0.5)
            end

            local targets = getTargets()
            if #targets == 0 then
                task.wait(0.5)
            else
                for _, tree in ipairs(targets) do
                    if not _Toggled or not _Running then break end
                    local success, treePos = pcall(function() return tree:GetPivot().Position end)
                    if success and treePos then
                        rootPart.Velocity = Vector3.new(0,0,0)
                        -- Position offset for better reach
                        rootPart.CFrame = CFrame.lookAt(treePos + Vector3.new(0, 2, 3), treePos)
                        task.wait(math.max(clickSpeed * 3, 0.08)) 
                    end
                end
            end
        else
            task.wait(0.2)
        end
    end
end)

