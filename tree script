local function getTargets()
    local found = {}
    local children = axeFolder:GetChildren()
    
    for _, obj in ipairs(children) do
        if string.find(obj.Name, "InfectedTree") and obj:GetAttribute("Destroyed") ~= true then
            table.insert(found, obj)
        end
        if #found >= treeCount then return found end 
    end
    
    if #found < treeCount then
        for _, obj in ipairs(children) do
            local isMatch = false
            if _MultiSelect then
                if (string.find(obj.Name, "Palm") or string.find(obj.Name, "Chaos")) then
                    isMatch = true
                end
            else
                if string.find(obj.Name, targetType) and targetType ~= "InfectedTree" then
                    isMatch = true
                end
            end
            
            if isMatch and obj:GetAttribute("Destroyed") ~= true then
                if not table.find(found, obj) then
                    table.insert(found, obj)
                end
            end
            
            if #found >= treeCount then break end
        end
    end
    
    return found
end

task.spawn(function()
    while _Running do
        if _Toggled then
            pcall(function() clickRemote:InvokeServer() end)
        end
        task.wait(clickSpeed)
    end
end)

task.spawn(function()
    while _Running do
        if _Toggled and rootPart then
            if not character:FindFirstChild("Axe") then
                toggleRemote:InvokeServer("Axe")
                task.wait(0.5)
            end

            local targets = getTargets()
            if #targets == 0 then
                task.wait(0.5)
            else
                for _, tree in ipairs(targets) do
                    if not _Toggled or not _Running then break end
                    local success, treePos = pcall(function() return tree:GetPivot().Position end)
                    if success and treePos then
                        rootPart.Velocity = Vector3.new(0,0,0)
                        rootPart.CFrame = CFrame.lookAt(treePos + Vector3.new(0, 1.5, 2.2), treePos)
                        task.wait(math.max(clickSpeed * 3, 0.08)) 
                    end
                end
            end
        else
            task.wait(0.2)
        end
    end
end)



