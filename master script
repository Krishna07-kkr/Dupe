-- [[ CONFIGURATION ]]
local SCRIPT_LIST = {
    "https://raw.githubusercontent.com/Krishna07-kkr/Dupe/refs/heads/main/autoclaim%20carrot",
    "https://raw.githubusercontent.com/Krishna07-kkr/Dupe/refs/heads/main/auto%20egg",
	"https://raw.githubusercontent.com/Krishna07-kkr/Dupe/refs/heads/main/medal%20merchant"
    "https://raw.githubusercontent.com/Krishna07-kkr/Dupe/refs/heads/main/auto%20rune"
    "https://raw.githubusercontent.com/Krishna07-kkr/Dupe/refs/heads/main/hatch%20webhook"
}

local WAIT_BETWEEN = 5 -- Seconds to wait between each script launch

-- [[ THE LOADER ]]
print("🚀 Master Loader: Initializing...")

for i, url in ipairs(SCRIPT_LIST) do
    if url == "" then continue end -- Skips empty quotes

    print("📡 Loading script " .. i .. "...")

    -- pcall keeps the loader alive even if the script errors
    local success, errorMessage = pcall(function()
        loadstring(game:HttpGet(url))()
    end)

    if success then
        print("✅ Script " .. i .. " loaded successfully.")
    else
        warn("❌ Script " .. i .. " failed! Error: " .. tostring(errorMessage))
    end

    -- Don't wait after the very last script
    if i < #SCRIPT_LIST then
        task.wait(WAIT_BETWEEN)
    end
end

print("🎉 Master Loader: Process complete.")
